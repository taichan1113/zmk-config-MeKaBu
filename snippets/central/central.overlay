#include "../listners.dtsi"

pointer: &listner_central{
  input-processors = <&zip_xy_transform INPUT_TRANSFORM_X_INVERT>;
  scroller {
    layers = <1>;
    input-processors = <&zip_xy_transform INPUT_TRANSFORM_X_INVERT>
    , <&zip_xy_transform INPUT_TRANSFORM_Y_INVERT>
    , <&zip_xy_to_scroll_mapper>
    ;
  };
};

&listner_peripheral {
  status = "okay";
};

