#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <input/processors.dtsi>
#include <input/processors/xyz.dtsi>
#include "../pinctrl_i2c.dtsi"
#include "../listners.dtsi"


// &gpio1 {
