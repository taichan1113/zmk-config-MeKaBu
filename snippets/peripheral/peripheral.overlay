/{
  split_inputs {
    #address-cells = <1>;
    #size-cells = <0>;
    pointer: split_peripheral@0 {
      compatible = "zmk,input-split";
      reg = <0>;
    };
  };

  listner_peripheral: listner_peripheral {
    compatible = "zmk,input-listener";
    status = "disabled";
    device = <&pointer>;
  };
};
